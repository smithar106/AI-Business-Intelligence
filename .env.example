# AI Ops Intelligence Suite — environment variables
#
# Copy this file to .env for local development, OR add these as
# variables in Railway / Streamlit Cloud secrets.
#
# All Claude calls use a STANDARD API key from console.anthropic.com.
# (Not an admin/workspace key — no admin endpoints are used anywhere.)

# Required by: Model Regression Tester, Spend Attribution, Benchmark Tracker
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Required by: Model Regression Tester
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GEMINI_API_KEY=AIxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Required by: Benchmark Tracker
HUGGINGFACE_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
