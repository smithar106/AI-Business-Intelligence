# Streamlit secrets format (used by st.secrets).
# Copy to .streamlit/secrets.toml for local runs. On Railway, set these
# as environment variables instead — the app reads st.secrets first and
# falls back to os.environ automatically.

ANTHROPIC_API_KEY = "sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
OPENAI_API_KEY = "sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
GEMINI_API_KEY = "AIxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
HUGGINGFACE_TOKEN = "hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
